.search-bar { display: flex; align-items: center; padding: 20rpx; background: #fff; }
.search-bar input { flex: 1; background: #f5f5f5; border-radius: 30rpx; padding: 15rpx 30rpx; font-size: 28rpx; margin-right: 20rpx; }
.search-bar text { color: #666; font-size: 28rpx; }
.results { padding: 20rpx; }
.product-card { display: flex; background: #fff; padding: 20rpx; margin-bottom: 20rpx; border-radius: 12rpx; }
.product-card image { width: 120rpx; height: 120rpx; margin-right: 20rpx; }
.info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.price { color: #e63946; font-size: 32rpx; font-weight: bold; margin-top: 10rpx; }
.empty { text-align: center; padding: 200rpx; color: #999; }