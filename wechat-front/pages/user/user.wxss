.user-header { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; background: linear-gradient(135deg, #e63946 0%, #ff6b6b 100%); }
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; background-color: #fff; margin-bottom: 20rpx; border: 4rpx solid rgba(255,255,255,0.3); }
.avatar-placeholder { width: 140rpx; height: 140rpx; border-radius: 50%; background-color: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 60rpx; margin-bottom: 20rpx; }
.username { color: #fff; font-size: 36rpx; font-weight: bold; }
.login-btn-header { background-color: #fff; color: #e63946; font-size: 28rpx; padding: 16rpx 50rpx; border-radius: 30rpx; }
.menu-list { background-color: #fff; margin-bottom: 20rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f5f5f5; font-size: 28rpx; }
.menu-item:last-child { border-bottom: none; }
.arrow { color: #999; }
.settings-section { background-color: #fff; padding: 30rpx; }
.lang-switch { display: flex; margin-left: auto; }
.lang-switch text { padding: 8rpx 20rpx; font-size: 24rpx; color: #666; border: 1rpx solid #ddd; border-radius: 4rpx; margin-left: 10rpx; }
.lang-switch text.active { color: #e63946; border-color: #e63946; }