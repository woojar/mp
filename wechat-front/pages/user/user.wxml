<view class="container">
  <view class="user-header">
    <block wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatarUrl || userInfo.avatar || '/assets/default-avatar.png'}}" />
      <text class="username">{{userInfo.nickName || userInfo.nickname || 'User'}}</text>
    </block>
    <block wx:else>
      <view class="avatar-placeholder">👤</view>
      <button class="login-btn-header" bindtap="onLogin">{{t.login}}</button>
    </block>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="onViewOrders">
      <text>{{t.myOrders}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onViewFavorites">
      <text>{{t.favorites}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onViewAddress">
      <text>{{t.addressBook}}</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onContactService">
      <text>{{t.contactService}}</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="settings-section">
    <view class="menu-item">
      <text>{{t.language}}</text>
      <view class="lang-switch">
        <text class="{{language === 'en' ? 'active' : ''}}" data-lang="en" bindtap="onSwitchLanguage">{{t.english}}</text>
        <text class="{{language === 'zh' ? 'active' : ''}}" data-lang="zh" bindtap="onSwitchLanguage">{{t.chinese}}</text>
      </view>
    </view>
  </view>
</view>